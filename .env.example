# ---- LLM 澶фā鍨嬮厤缃?----
# Anthropic Claude API锛堟垨鍏煎鎺ュ彛锛?# 鏀寔 ANTHROPIC_API_KEY 鎴?ANTHROPIC_AUTH_TOKEN 涓ょ鍙橀噺鍚?ANTHROPIC_API_KEY=your-api-key-here
# ANTHROPIC_AUTH_TOKEN=your-token-here
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ---- MCP 鏈嶅姟鍣?----
# 榛樿 MCP 鏈嶅姟鍣ㄥ湴鍧€锛堢敤浜庨璁?Agent 鐨勫伐鍏锋簮锛?MCP_SERVER_URL=http://localhost:10001/mcp

# ---- 鏈嶅姟绔彛 ----
PLATFORM_PORT=8081

# ---- 瀹夊叏閰嶇疆 ----
# 棣栨鍚姩鏃惰嚜鍔ㄥ垱寤虹殑绠＄悊鍛樺瘑鐮?DEFAULT_ADMIN_PASSWORD=admin123

# ---- 宸ュ叿閲嶈瘯 ----
TOOL_MAX_RETRIES=3
TOOL_RETRY_DELAY=2.0

# ---- PDF 鎶ュ憡 ----
# 涓枃瀛椾綋璺緞锛圠inux 浣跨敤 wqy-zenhei锛學indows 浣跨敤 msyh锛?# PDF_FONT_DIR=/usr/share/fonts/truetype/wqy
# PDF_FONT_REGULAR=/usr/share/fonts/truetype/wqy/wqy-zenhei.ttc
# PDF_FONT_BOLD=/usr/share/fonts/truetype/wqy/wqy-zenhei.ttc
PDF_WATERMARK_TEXT=boguan
